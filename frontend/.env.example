# 이 파일은 예시입니다. 실제 값은 넣지 마세요.
#
# 로컬: frontend/.env.local 에만 실제 값을 두세요 (.gitignore 됨).
# Vercel: Project Settings → Environment Variables 에서
#   Production / Preview(및 필요 시 Development)에 아래 키만 등록하세요.
#
# 금지: 서비스 롤(service role) 키를 NEXT_PUBLIC_ 으로 두거나 클라이언트에 노출하지 마세요.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase → Authentication → URL Configuration (로컬 개발 예시)
# - Site URL: http://localhost:3000
# - Redirect URLs 예: http://localhost:3000/auth/callback , http://localhost:3000/reset-password
# 프로덕션·Vercel URL은 저장소 루트 README.md 배포 섹션을 참고하세요.
#
# MVP: Confirm email OFF 권장 시 Authentication 설정에서 확인
